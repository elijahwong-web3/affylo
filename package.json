{
  "name": "affylo",
  "version": "1.0.0",
  "description": "A private group chart builder for corporate legal and finance teams",
  "author": "Elijah Wong",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "electron:dev": "nuxt build && electron .",
    "electron:build": "nuxt build && electron-builder --mac --publish never"
  },
  "dependencies": {
    "@vue/server-renderer": "^3.5.13",
    "firebase": "^12.9.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.2",
    "nuxt": "^3.14.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.elijahwong.affylo",
    "productName": "Affylo",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/main.cjs"
    ],
    "extraResources": [
      {
        "from": ".output",
        "to": ".output",
        "filter": ["**/*"]
      },
      {
        "from": "data",
        "to": "data",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.business",
      "icon": "build/icon.icns",
      "identity": null
    },
    "dmg": {
      "icon": "build/icon.icns",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 90,
          "type": "file",
          "path": "README.md"
        },
        {
          "x": 290,
          "y": 90,
          "type": "file",
          "path": "LICENSE"
        }
      ],
      "title": "Affylo ${version}"
    }
  }
}
