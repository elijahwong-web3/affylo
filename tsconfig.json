{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["@nuxt/schema"]
  },
  "include": ["**/*.ts", "**/*.vue", ".nuxt/nuxt.d.ts"],
  "exclude": ["node_modules"]
}
